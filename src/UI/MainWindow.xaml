<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Win11 Esports Optimizer Pro"
        Height="800" Width="1400"
        Background="#0f172a"
        Foreground="#f8fafc"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Semibold"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="AccentColor">#3b82f6</Color>
        <Color x:Key="AccentHoverColor">#60a5fa</Color>
        <Color x:Key="SurfaceColor">#1e293b</Color>
        <Color x:Key="SurfaceLightColor">#334155</Color>
        <Color x:Key="BackgroundColor">#0f172a</Color>
        <Color x:Key="TextPrimaryColor">#f8fafc</Color>
        <Color x:Key="TextSecondaryColor">#94a3b8</Color>
        <Color x:Key="SuccessColor">#10b981</Color>
        <Color x:Key="DangerColor">#ef4444</Color>

        <!-- Palette -->
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
        <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>

        <!-- Glass Effect -->
        <Style x:Key="GlassBorder" TargetType="Border">
            <Setter Property="Background" Value="#CC1e293b"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceLightBrush}"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.25" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Switch Style -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Toggle Track -->
                            <Border x:Name="Border" Width="48" Height="26" CornerRadius="13" Background="#ef4444" BorderBrush="#475569" BorderThickness="1">
                                <Grid>
                                    <Ellipse x:Name="Knob" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.3"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Grid>
                            </Border>
                            
                            <!-- Content -->
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#10b981"/> <!-- Green when ON -->
                                <Setter TargetName="Border" Property="BorderBrush" Value="#10b981"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Tab Button Style -->
        <Style TargetType="Button" x:Key="SidebarTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Margin="12,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"> <!-- Selected State -->
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="15" Opacity="0.4" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animations -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="30" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Window Controls -->
        <Style TargetType="Button" x:Key="WinCtrl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0,0,6,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,40,0,60">
                    <TextBlock Text="OPTIMIZER PRO" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <Border Background="#334155" HorizontalAlignment="Center" CornerRadius="4" Padding="8,2" Margin="0,8,0,0">
                        <TextBlock Text="ESPORTS EDITION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <Button Content="Dashboard" Style="{StaticResource SidebarTab}" Name="BtnNavDashboard" IsEnabled="False"/>
                    <Button Content="Tweaks" Style="{StaticResource SidebarTab}" Name="BtnNavTweaks"/>
                    <Button Content="Benchmarks" Style="{StaticResource SidebarTab}" Name="BtnNavBenchmarks"/>
                    <Button Content="Logs" Style="{StaticResource SidebarTab}" Name="BtnNavLogs"/>
                    <Button Content="Settings" Style="{StaticResource SidebarTab}" Name="BtnNavSettings"/>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,24">
                    <TextBlock Text="v2.0.7" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" FontSize="12" Opacity="0.7"/>
                    <TextBlock Text="Created by Howl" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" FontSize="11" Opacity="0.5" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0">
                <TextBlock Name="TxtPageTitle" Text="System Dashboard" VerticalAlignment="Center" Margin="40,0,0,0" FontSize="22" FontWeight="Bold" Foreground="White">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.4" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,12,0">
                    <Button Name="BtnMinimize" Style="{StaticResource WinCtrl}" Content="_" FontSize="14" VerticalContentAlignment="Bottom"/>
                    <Button Name="BtnClose" Style="{StaticResource WinCtrl}" Content="X" FontSize="14" Foreground="{StaticResource DangerBrush}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0,0,6,6">
                                    <TextBlock Text="X" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="40,10,40,40">
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
                    </EventTrigger>
                </Grid.Triggers>

                <!-- VIEW: DASHBOARD -->
                <Grid Name="ViewDashboard" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Hardware Stats -->
                    <Border Grid.Row="0" Style="{StaticResource GlassBorder}" Padding="30" Margin="0,0,0,32">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="GPU MODEL" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Name="TxtGpuModel" Text="Detecting..." Foreground="White" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Rectangle Grid.Column="1" Width="1" Fill="#334155" Margin="30,4"/>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CPU MODEL" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Name="TxtCpuModel" Text="Detecting..." Foreground="White" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Rectangle Grid.Column="3" Width="1" Fill="#334155" Margin="30,4"/>
                            
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="WINDOWS VERSION" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Name="TxtOsVersion" Text="Detecting..." Foreground="White" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Metrics -->
                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,32">
                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,24,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="CPU Load" Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" HorizontalAlignment="Right">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="6" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Grid>
                                <TextBlock Name="TxtCpuUsage" Text="0%" FontSize="48" FontWeight="Bold" Foreground="White"/>
                                <ProgressBar Name="PbCpu" Value="0" Maximum="100" Margin="0,16,0,8" Height="4"/>
                                <TextBlock Name="TxtCpuDetails" Text="..." FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,24,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="Memory" Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                                    <Ellipse Width="8" Height="8" Fill="#8b5cf6" HorizontalAlignment="Right">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#8b5cf6" BlurRadius="6" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Grid>
                                <TextBlock Name="TxtRamUsage" Text="0%" FontSize="48" FontWeight="Bold" Foreground="White"/>
                                <ProgressBar Name="PbRam" Value="0" Maximum="100" Margin="0,16,0,8" Height="4" Foreground="#8b5cf6"/>
                                <TextBlock Name="TxtRamDetails" Text="..." FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassBorder}" Padding="24">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="Health" Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" HorizontalAlignment="Right">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="{StaticResource SuccessColor}" BlurRadius="6" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Grid>
                                <TextBlock Name="TxtScore" Text="GOOD" FontSize="48" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                <ProgressBar Value="100" Maximum="100" Margin="0,16,0,8" Height="4" Foreground="{StaticResource SuccessBrush}"/>
                                <TextBlock Text="System Optimized" FontSize="12" Foreground="{StaticResource SuccessBrush}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Action Button -->
                    <Button Grid.Row="2" Name="BtnRunOptimization" Content="RUN OPTIMIZATION" Height="64" FontSize="18" FontWeight="Bold" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,32">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                        <Setter TargetName="border" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="20" Opacity="0.4" ShadowDepth="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Logs -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Live Activity" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>
                        <Border Grid.Row="1" Style="{StaticResource GlassBorder}" Padding="16">
                            <TextBox Name="TxtLogPreview" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- VIEW: TWEAKS -->
                <Grid Name="ViewTweaks" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Performance Modules" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,32"/>
                        
                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Network Icon (Vector) -->
                                <Path Grid.Column="0" Fill="{StaticResource AccentBrush}" Data="M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M16.59,12L15.17,10.59L12,13.76L8.83,10.59L7.41,12L12,16.59L16.59,12Z" Height="40" Width="40" Stretch="Uniform" Margin="0,0,24,0"/>

                                <StackPanel Grid.Column="1">
                                    <CheckBox Name="ChkTweakNetwork" Style="{StaticResource ToggleSwitch}" Content="Network Optimization" Foreground="White" FontSize="18" FontWeight="Bold" IsChecked="True"/>
                                    <TextBlock Text="Optimizes TCP/IP stack, disables Nagle's algorithm, and tunes QoS for low latency." Foreground="{StaticResource TextSecondary}" Margin="64,8,0,0" TextWrapping="Wrap" FontSize="14" LineHeight="22"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- CPU Icon -->
                                <Path Grid.Column="0" Fill="{StaticResource AccentBrush}" Data="M17,17H7V7H17M21,11V9H19V7C19,5.89 18.1,5 17,5H15V3H13V5H11V3H9V5H7C5.89,5 5,5.89 5,7V9H3V11H5V13H3V15H5V17A2,2 0 0,0 7,19H9V21H11V19H13V21H15V19H17A2,2 0 0,0 19,17V15H21V13H19V11M13,13H11V11H13M15,9H9V15H15V9Z" Height="40" Width="40" Stretch="Uniform" Margin="0,0,24,0"/>

                                <StackPanel Grid.Column="1">
                                    <CheckBox Name="ChkTweakCpu" Style="{StaticResource ToggleSwitch}" Content="CPU Optimization" Foreground="White" FontSize="18" FontWeight="Bold" IsChecked="True"/>
                                    <TextBlock Text="Unlocks Ultimate Performance plan, disables core parking, and applies vendor-specific tweaks." Foreground="{StaticResource TextSecondary}" Margin="64,8,0,0" TextWrapping="Wrap" FontSize="14" LineHeight="22"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- GPU Icon -->
                                <Path Grid.Column="0" Fill="{StaticResource AccentBrush}" Data="M4,8H8V4H20V16H16V20H4V8M16,8V14H20V6H12V8H16M6,12V18H14V10H6V12Z" Height="40" Width="40" Stretch="Uniform" Margin="0,0,24,0"/>

                                <StackPanel Grid.Column="1">
                                    <CheckBox Name="ChkTweakGpu" Style="{StaticResource ToggleSwitch}" Content="GPU Optimization" Foreground="White" FontSize="18" FontWeight="Bold" IsChecked="True"/>
                                    <TextBlock Text="Enables HAGS, MSI Mode for GPU/NIC, and optimizes shader cache." Foreground="{StaticResource TextSecondary}" Margin="64,8,0,0" TextWrapping="Wrap" FontSize="14" LineHeight="22"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Debloat Icon -->
                                <Path Grid.Column="0" Fill="{StaticResource AccentBrush}" Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Height="40" Width="40" Stretch="Uniform" Margin="0,0,24,0"/>

                                <StackPanel Grid.Column="1">
                                    <CheckBox Name="ChkTweakServices" Style="{StaticResource ToggleSwitch}" Content="System Debloat" Foreground="White" FontSize="18" FontWeight="Bold" IsChecked="True"/>
                                    <TextBlock Text="Disables telemetry, bloatware apps, and non-essential background services." Foreground="{StaticResource TextSecondary}" Margin="64,8,0,0" TextWrapping="Wrap" FontSize="14" LineHeight="22"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Input Icon -->
                                <Path Grid.Column="0" Fill="{StaticResource AccentBrush}" Data="M15,7H9V1H15M13,15H11V9H13M19,13H16.5L15,20H9L7.5,13H5A2,2 0 0,0 3,15V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V15A2,2 0 0,0 19,13Z" Height="40" Width="40" Stretch="Uniform" Margin="0,0,24,0"/>

                                <StackPanel Grid.Column="1">
                                    <CheckBox Name="ChkTweakInput" Style="{StaticResource ToggleSwitch}" Content="Input Latency" Foreground="White" FontSize="18" FontWeight="Bold" IsChecked="True"/>
                                    <TextBlock Text="Reduces USB polling intervals and optimizes mouse/keyboard data queues." Foreground="{StaticResource TextSecondary}" Margin="64,8,0,0" TextWrapping="Wrap" FontSize="14" LineHeight="22"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- VIEW: BENCHMARKS -->
                <Grid Name="ViewBenchmarks" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="System Benchmarks" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,32"/>
                        
                        <Border Style="{StaticResource GlassBorder}" Padding="32" Margin="0,0,0,24">
                            <StackPanel>
                                <Grid Margin="0,0,0,24">
                                    <StackPanel>
                                        <TextBlock Text="Network Latency" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="Ping test to Cloudflare DNS (1.1.1.1)" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Name="BtnRunPing" Content="START TEST" Width="140" HorizontalAlignment="Right" Background="#334155" Foreground="White" BorderThickness="0" Padding="0,10" FontWeight="Bold">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                
                                <Grid>
                                    <ProgressBar Name="PbPing" Height="8" Maximum="100" Value="0" Background="#334155" Foreground="{StaticResource AccentBrush}"/>
                                </Grid>
                                <TextBlock Name="TxtPingResult" Text="Ready to start" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,0" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassBorder}" Padding="32">
                            <StackPanel>
                                <Grid Margin="0,0,0,24">
                                    <StackPanel>
                                        <TextBlock Text="Disk Performance" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="Sequential Read/Write throughput" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Name="BtnRunDisk" Content="START TEST" Width="140" HorizontalAlignment="Right" Background="#334155" Foreground="White" BorderThickness="0" Padding="0,10" FontWeight="Bold">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                
                                <Grid>
                                    <ProgressBar Name="PbDisk" Height="8" Maximum="1000" Value="0" Background="#334155" Foreground="{StaticResource AccentBrush}"/>
                                </Grid>
                                <TextBlock Name="TxtDiskResult" Text="Ready to start" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,0" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- VIEW: LOGS -->
                <Grid Name="ViewLogs" Visibility="Collapsed">
                    <Border Style="{StaticResource GlassBorder}" Padding="24">
                        <TextBox Name="TxtFullLog" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="14" LineHeight="20"/>
                    </Border>
                </Grid>

                <!-- VIEW: SETTINGS -->
                <Grid Name="ViewSettings" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Application Settings" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,32"/>
                        <Border Style="{StaticResource GlassBorder}" Padding="32">
                            <StackPanel>
                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Create System Restore Point" IsChecked="True" Foreground="White" Margin="0,0,0,24" FontSize="16" FontWeight="SemiBold"/>
                                <CheckBox Style="{StaticResource ToggleSwitch}" Content="Enable File Logging" IsChecked="True" Foreground="White" Margin="0,0,0,24" FontSize="16" FontWeight="SemiBold"/>
                                <CheckBox Name="ChkUpdates" Style="{StaticResource ToggleSwitch}" Content="Check for Updates on Startup" IsChecked="True" Foreground="White" Margin="0,0,0,24" FontSize="16" FontWeight="SemiBold"/>
                                
                                <Rectangle Height="1" Fill="#334155" Margin="0,8,0,32"/>
                                
                                <Button Content="RESET TO DEFAULTS" Width="220" HorizontalAlignment="Left" Padding="0,14" Background="#ef4444" Foreground="White" BorderThickness="0" FontWeight="Bold">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
