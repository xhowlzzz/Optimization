<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Win11 Esports Optimizer Pro"
        Height="768" Width="1366"
        Background="#0f172a"
        Foreground="#f8fafc"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Semibold"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#3b82f6"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1e293b"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#0f172a"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#f8fafc"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94a3b8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#10b981"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#ef4444"/>

        <!-- Navigation Button Style -->
        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="0,4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"> <!-- Selected State Simulation -->
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Background" Value="#1e293b"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Button Style -->
        <Style TargetType="Button" x:Key="WindowControlBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <StackPanel Grid.Row="0" Margin="0,20,0,40">
                    <TextBlock Text="OPTIMIZER PRO" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="ESPORTS EDITION" FontSize="11" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Opacity="0.9" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <Button Content="Dashboard" Style="{StaticResource NavButton}" Name="BtnNavDashboard" IsEnabled="False"/>
                    <Button Content="Tweaks" Style="{StaticResource NavButton}" Name="BtnNavTweaks"/>
                    <Button Content="Benchmarks" Style="{StaticResource NavButton}" Name="BtnNavBenchmarks"/>
                    <Button Content="Logs" Style="{StaticResource NavButton}" Name="BtnNavLogs"/>
                    <Button Content="Settings" Style="{StaticResource NavButton}" Name="BtnNavSettings"/>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                    <TextBlock Text="v2.0.4-stable" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar / Drag Area -->
            <Border Grid.Row="0" Background="Transparent" Name="TitleBar">
                <Grid>
                    <TextBlock Name="TxtPageTitle" Text="System Dashboard" VerticalAlignment="Center" Margin="32,0,0,0" FontSize="18" Foreground="{StaticResource TextSecondary}"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Name="BtnMinimize" Style="{StaticResource WindowControlBtn}" Content="_" FontSize="14" VerticalContentAlignment="Bottom"/>
                        <Button Name="BtnClose" Style="{StaticResource WindowControlBtn}" Content="X" FontSize="14" Foreground="{StaticResource DangerBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <TextBlock Text="X" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Views Container -->
            <Grid Grid.Row="1" Margin="32,10,32,32">
                
                <!-- VIEW: DASHBOARD -->
                <Grid Name="ViewDashboard" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Hardware Info -->
                        <RowDefinition Height="Auto"/> <!-- Metrics -->
                        <RowDefinition Height="Auto"/> <!-- Action -->
                        <RowDefinition Height="*"/>    <!-- Activity -->
                    </Grid.RowDefinitions>

                    <!-- Hardware Info Panel -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- GPU -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="GPU Model" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                <TextBlock Name="TxtGpuModel" Text="Detecting..." Foreground="White" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Rectangle Grid.Column="1" Width="1" Fill="#334155" Margin="20,4"/>
                            
                            <!-- CPU -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CPU Model" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                <TextBlock Name="TxtCpuModel" Text="Detecting..." Foreground="White" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Rectangle Grid.Column="3" Width="1" Fill="#334155" Margin="20,4"/>
                            
                            <!-- OS -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Windows Edition" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                <TextBlock Name="TxtOsVersion" Text="Detecting..." Foreground="White" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Metrics Cards -->
                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,24">
                        <!-- CPU Card -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="CPU Usage" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                <TextBlock Name="TxtCpuUsage" Text="0%" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,8"/>
                                <ProgressBar Name="PbCpu" Value="0" Maximum="100"/>
                                <TextBlock Name="TxtCpuDetails" Text="Waiting for data..." FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- RAM Card -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="RAM Usage" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                <TextBlock Name="TxtRamUsage" Text="0%" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,8"/>
                                <ProgressBar Name="PbRam" Value="0" Maximum="100"/>
                                <TextBlock Name="TxtRamDetails" Text="Waiting for data..." FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- Health Card -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <TextBlock Text="System Health" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                <TextBlock Name="TxtScore" Text="GOOD" FontSize="36" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,8"/>
                                <ProgressBar Value="100" Maximum="100" Foreground="{StaticResource SuccessBrush}"/>
                                <TextBlock Text="Ready for optimization" FontSize="11" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Main Action -->
                    <Button Grid.Row="2" Name="BtnRunOptimization" Content="RUN SYSTEM OPTIMIZATION" Background="{StaticResource AccentBrush}" Foreground="White" FontSize="16" FontWeight="Bold" Padding="0,18" Margin="0,0,0,24" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="#94a3b8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Activity Log -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Recent Activity" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12"/>
                        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16">
                            <TextBox Name="TxtLogPreview" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- VIEW: TWEAKS -->
                <Grid Name="ViewTweaks" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Performance Modules" FontSize="18" Foreground="White" Margin="0,0,0,20"/>
                        
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox Name="ChkTweakNetwork" Content="Network Optimization" Foreground="White" FontSize="15" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Optimizes TCP/IP stack, disables Nagle's algorithm, and tunes QoS for low latency." Foreground="{StaticResource TextSecondary}" Margin="24,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox Name="ChkTweakCpu" Content="CPU Optimization" Foreground="White" FontSize="15" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Unlocks Ultimate Performance plan, disables core parking, and applies vendor-specific tweaks." Foreground="{StaticResource TextSecondary}" Margin="24,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox Name="ChkTweakGpu" Content="GPU Optimization" Foreground="White" FontSize="15" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Enables HAGS, MSI Mode for GPU/NIC, and optimizes shader cache." Foreground="{StaticResource TextSecondary}" Margin="24,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox Name="ChkTweakServices" Content="System Debloat" Foreground="White" FontSize="15" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Disables telemetry, bloatware apps, and non-essential background services." Foreground="{StaticResource TextSecondary}" Margin="24,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox Name="ChkTweakInput" Content="Input Latency" Foreground="White" FontSize="15" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Reduces USB polling intervals and optimizes mouse/keyboard data queues." Foreground="{StaticResource TextSecondary}" Margin="24,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- VIEW: BENCHMARKS -->
                <Grid Name="ViewBenchmarks" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Benchmarks" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Performance testing suite coming in v2.1" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,8"/>
                    </StackPanel>
                </Grid>

                <!-- VIEW: LOGS -->
                <Grid Name="ViewLogs" Visibility="Collapsed">
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16">
                        <TextBox Name="TxtFullLog" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
                    </Border>
                </Grid>

                <!-- VIEW: SETTINGS -->
                <Grid Name="ViewSettings" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Application Settings" FontSize="18" Foreground="White" Margin="0,0,0,20"/>
                        <CheckBox Content="Create System Restore Point" IsChecked="True" Foreground="White" Margin="0,0,0,12"/>
                        <CheckBox Content="Enable File Logging" IsChecked="True" Foreground="White" Margin="0,0,0,12"/>
                        <CheckBox Content="Check for Updates on Startup" IsChecked="True" Foreground="White" Margin="0,0,0,12"/>
                        <Button Content="Reset Configuration" Width="200" HorizontalAlignment="Left" Padding="10" Margin="0,20,0,0"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
