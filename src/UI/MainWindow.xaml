<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Win11 Esports Optimizer Pro"
        Height="720" Width="1080"
        Background="#0f172a"
        Foreground="#f8fafc"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Semibold"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#3b82f6"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1e293b"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#f8fafc"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94a3b8"/>
        
        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" Padding="16">
            <StackPanel>
                <TextBlock Text="OPTIMIZER PRO" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,32" HorizontalAlignment="Center"/>
                
                <Button Content="Dashboard" Style="{StaticResource NavButton}" Name="BtnNavDashboard"/>
                <Button Content="Tweaks" Style="{StaticResource NavButton}" Name="BtnNavTweaks"/>
                <Button Content="Benchmarks" Style="{StaticResource NavButton}" Name="BtnNavBenchmarks"/>
                <Button Content="Logs" Style="{StaticResource NavButton}" Name="BtnNavLogs"/>
                <Button Content="Settings" Style="{StaticResource NavButton}" Name="BtnNavSettings"/>
                
                <StackPanel VerticalAlignment="Bottom" Margin="0,300,0,0">
                    <TextBlock Text="v2.0.0" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,24">
                <TextBlock Name="TxtPageTitle" Text="System Dashboard" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <Button Name="BtnClose" Content="✕" DockPanel.Dock="Right" Background="Transparent" Foreground="#ef4444" FontSize="18" BorderThickness="0" Cursor="Hand"/>
                <Button Name="BtnMinimize" Content="—" DockPanel.Dock="Right" Background="Transparent" Foreground="{StaticResource TextSecondary}" FontSize="18" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
            </DockPanel>

            <!-- Pages -->
            <Grid Grid.Row="1">
                <!-- Dashboard View -->
                <StackPanel Name="ViewDashboard">
                    <UniformGrid Columns="3" Margin="0,0,0,24">
                        <!-- CPU Card -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="CPU Usage" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                <TextBlock Name="TxtCpuUsage" Text="0%" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,4"/>
                                <ProgressBar Name="PbCpu" Value="0" Maximum="100"/>
                                <TextBlock Name="TxtCpuName" Text="Loading..." FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <!-- RAM Card -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="RAM Usage" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                <TextBlock Name="TxtRamUsage" Text="0%" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,4"/>
                                <ProgressBar Name="PbRam" Value="0" Maximum="100"/>
                                <TextBlock Name="TxtRamDetails" Text="Loading..." FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- Optimization Score -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Health Score" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                <TextBlock Name="TxtScore" Text="85%" FontSize="32" FontWeight="Bold" Foreground="#10b981" Margin="0,4"/>
                                <ProgressBar Value="85" Maximum="100" Foreground="#10b981"/>
                                <TextBlock Text="System is optimized" FontSize="11" Foreground="#10b981" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Button Name="BtnRunOptimization" Content="RUN SYSTEM OPTIMIZATION" Background="{StaticResource AccentBrush}" Foreground="White" FontSize="16" FontWeight="Bold" Padding="0,16" Margin="0,0,0,24" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Text="Recent Activity" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16" Height="200">
                        <TextBox Name="TxtLogPreview" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </StackPanel>

                <!-- Tweaks View (Hidden by default) -->
                <ScrollViewer Name="ViewTweaks" Visibility="Collapsed">
                    <StackPanel>
                        <CheckBox Name="ChkTweakNetwork" Content="Network Optimization (TCP/IP, QoS)" Foreground="White" FontSize="14" Margin="0,0,0,12" IsChecked="True"/>
                        <CheckBox Name="ChkTweakCpu" Content="CPU Power Plan &amp; Unparking" Foreground="White" FontSize="14" Margin="0,0,0,12" IsChecked="True"/>
                        <CheckBox Name="ChkTweakGpu" Content="GPU HAGS &amp; MSI Mode" Foreground="White" FontSize="14" Margin="0,0,0,12" IsChecked="True"/>
                        <CheckBox Name="ChkTweakServices" Content="Disable Telemetry &amp; Bloatware" Foreground="White" FontSize="14" Margin="0,0,0,12" IsChecked="True"/>
                        <CheckBox Name="ChkTweakInput" Content="Low Latency Input (USB Polling)" Foreground="White" FontSize="14" Margin="0,0,0,12" IsChecked="True"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
