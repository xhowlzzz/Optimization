<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Win11 Esports Optimizer Pro"
        Height="768" Width="1366"
        Background="#0f172a"
        Foreground="#f8fafc"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Semibold"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="AccentBrush" Color="#3b82f6"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#60a5fa"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1e293b"/>
        <SolidColorBrush x:Key="SurfaceLightBrush" Color="#334155"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#0f172a"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#f8fafc"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94a3b8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#10b981"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#ef4444"/>

        <!-- Glass Effect (Simulated with semi-transparent dark + shadow) -->
        <Style x:Key="GlassBorder" TargetType="Border">
            <Setter Property="Background" Value="#CC1e293b"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="10" Opacity="0.3" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animations -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Navigation Button Style -->
        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Margin="0,4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"> <!-- Selected State -->
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#1e293b"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2,0,0,0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Main Action Button Style -->
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0,18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#94a3b8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Button Style -->
        <Style TargetType="Button" x:Key="WindowControlBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Grid>
                                <Rectangle x:Name="PART_Track"/>
                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" CornerRadius="3"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <StackPanel Grid.Row="0" Margin="0,30,0,50">
                    <TextBlock Text="OPTIMIZER PRO" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="ESPORTS EDITION" FontSize="11" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Opacity="0.9" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <Button Content="Dashboard" Style="{StaticResource NavButton}" Name="BtnNavDashboard" IsEnabled="False"/>
                    <Button Content="Tweaks" Style="{StaticResource NavButton}" Name="BtnNavTweaks"/>
                    <Button Content="Benchmarks" Style="{StaticResource NavButton}" Name="BtnNavBenchmarks"/>
                    <Button Content="Logs" Style="{StaticResource NavButton}" Name="BtnNavLogs"/>
                    <Button Content="Settings" Style="{StaticResource NavButton}" Name="BtnNavSettings"/>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                    <TextBlock Text="v2.0.5 | Created by Howl" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar / Drag Area -->
            <Border Grid.Row="0" Background="Transparent" Name="TitleBar" Margin="0,0,0,0">
                <Grid>
                    <TextBlock Name="TxtPageTitle" Text="System Dashboard" VerticalAlignment="Center" Margin="32,0,0,0" FontSize="20" FontWeight="SemiBold" Foreground="White">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button Name="BtnMinimize" Style="{StaticResource WindowControlBtn}" Content="_" FontSize="14" VerticalContentAlignment="Bottom"/>
                        <Button Name="BtnClose" Style="{StaticResource WindowControlBtn}" Content="X" FontSize="14" Foreground="{StaticResource DangerBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="0,0,0,4">
                                        <TextBlock Text="X" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Views Container -->
            <Grid Grid.Row="1" Margin="32,10,32,32">
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
                    </EventTrigger>
                </Grid.Triggers>
                
                <!-- VIEW: DASHBOARD -->
                <Grid Name="ViewDashboard" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Hardware Info -->
                        <RowDefinition Height="Auto"/> <!-- Metrics -->
                        <RowDefinition Height="Auto"/> <!-- Action -->
                        <RowDefinition Height="*"/>    <!-- Activity -->
                    </Grid.RowDefinitions>

                    <!-- Hardware Info Panel -->
                    <Border Grid.Row="0" Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,0,32">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- GPU -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="GPU Model" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Name="TxtGpuModel" Text="Detecting..." Foreground="White" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Rectangle Grid.Column="1" Width="1" Fill="#334155" Margin="24,4"/>
                            
                            <!-- CPU -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CPU Model" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Name="TxtCpuModel" Text="Detecting..." Foreground="White" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Rectangle Grid.Column="3" Width="1" Fill="#334155" Margin="24,4"/>
                            
                            <!-- OS -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Windows Edition" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Name="TxtOsVersion" Text="Detecting..." Foreground="White" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Metrics Cards -->
                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,32">
                        <!-- CPU Card -->
                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,24,0">
                            <StackPanel>
                                <TextBlock Text="CPU Usage" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                <TextBlock Name="TxtCpuUsage" Text="0%" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,12"/>
                                <ProgressBar Name="PbCpu" Value="0" Maximum="100"/>
                                <TextBlock Name="TxtCpuDetails" Text="Waiting for data..." FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- RAM Card -->
                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,24,0">
                            <StackPanel>
                                <TextBlock Text="RAM Usage" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                <TextBlock Name="TxtRamUsage" Text="0%" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,12"/>
                                <ProgressBar Name="PbRam" Value="0" Maximum="100"/>
                                <TextBlock Name="TxtRamDetails" Text="Waiting for data..." FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- Health Card -->
                        <Border Style="{StaticResource GlassBorder}" Padding="24">
                            <StackPanel>
                                <TextBlock Text="System Health" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                <TextBlock Name="TxtScore" Text="GOOD" FontSize="42" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,12"/>
                                <ProgressBar Value="100" Maximum="100" Foreground="{StaticResource SuccessBrush}"/>
                                <TextBlock Text="Ready for optimization" FontSize="12" Foreground="{StaticResource SuccessBrush}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Main Action -->
                    <Button Grid.Row="2" Name="BtnRunOptimization" Content="RUN SYSTEM OPTIMIZATION" Style="{StaticResource ActionBtn}" Margin="0,0,0,32"/>

                    <!-- Activity Log -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Recent Activity" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>
                        <Border Grid.Row="1" Style="{StaticResource GlassBorder}" Padding="16">
                            <TextBox Name="TxtLogPreview" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- VIEW: TWEAKS -->
                <Grid Name="ViewTweaks" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Performance Modules" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,24"/>
                        
                        <Border Style="{StaticResource GlassBorder}" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Name="ChkTweakNetwork" Content="Network Optimization" Foreground="White" FontSize="16" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Optimizes TCP/IP stack, disables Nagle's algorithm, and tunes QoS for low latency." Foreground="{StaticResource TextSecondary}" Margin="24,6,0,0" TextWrapping="Wrap" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassBorder}" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Name="ChkTweakCpu" Content="CPU Optimization" Foreground="White" FontSize="16" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Unlocks Ultimate Performance plan, disables core parking, and applies vendor-specific tweaks." Foreground="{StaticResource TextSecondary}" Margin="24,6,0,0" TextWrapping="Wrap" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassBorder}" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Name="ChkTweakGpu" Content="GPU Optimization" Foreground="White" FontSize="16" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Enables HAGS, MSI Mode for GPU/NIC, and optimizes shader cache." Foreground="{StaticResource TextSecondary}" Margin="24,6,0,0" TextWrapping="Wrap" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassBorder}" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Name="ChkTweakServices" Content="System Debloat" Foreground="White" FontSize="16" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Disables telemetry, bloatware apps, and non-essential background services." Foreground="{StaticResource TextSecondary}" Margin="24,6,0,0" TextWrapping="Wrap" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource GlassBorder}" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Name="ChkTweakInput" Content="Input Latency" Foreground="White" FontSize="16" FontWeight="SemiBold" IsChecked="True"/>
                                <TextBlock Text="Reduces USB polling intervals and optimizes mouse/keyboard data queues." Foreground="{StaticResource TextSecondary}" Margin="24,6,0,0" TextWrapping="Wrap" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- VIEW: BENCHMARKS -->
                <Grid Name="ViewBenchmarks" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="System Benchmarks" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,24"/>
                        
                        <Border Style="{StaticResource GlassBorder}" Padding="24" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Network Latency" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Name="PbPing" Height="10" Maximum="100" Value="0" VerticalAlignment="Center"/>
                                    <TextBlock Name="TxtPingResult" Text="Ready" Grid.Column="1" Foreground="{StaticResource TextSecondary}" Margin="16,0,0,0"/>
                                </Grid>
                                <Button Name="BtnRunPing" Content="Test Latency" Width="150" HorizontalAlignment="Left" Style="{StaticResource NavButton}" Background="#334155" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassBorder}" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Disk Performance" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                <TextBlock Text="Sequential Read/Write test" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,16"/>
                                <Button Name="BtnRunDisk" Content="Run Disk Test" Width="150" HorizontalAlignment="Left" Style="{StaticResource NavButton}" Background="#334155" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- VIEW: LOGS -->
                <Grid Name="ViewLogs" Visibility="Collapsed">
                    <Border Style="{StaticResource GlassBorder}" Padding="20">
                        <TextBox Name="TxtFullLog" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13"/>
                    </Border>
                </Grid>

                <!-- VIEW: SETTINGS -->
                <Grid Name="ViewSettings" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Application Settings" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,24"/>
                        <Border Style="{StaticResource GlassBorder}" Padding="24">
                            <StackPanel>
                                <CheckBox Content="Create System Restore Point" IsChecked="True" Foreground="White" Margin="0,0,0,16" FontSize="14"/>
                                <CheckBox Content="Enable File Logging" IsChecked="True" Foreground="White" Margin="0,0,0,16" FontSize="14"/>
                                <CheckBox Content="Check for Updates on Startup" IsChecked="True" Foreground="White" Margin="0,0,0,16" FontSize="14"/>
                                <Button Content="Reset Configuration" Width="200" HorizontalAlignment="Left" Padding="12" Margin="0,16,0,0" Background="#334155" Foreground="White" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
